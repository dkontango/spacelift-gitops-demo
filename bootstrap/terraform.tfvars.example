# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
# spacelift_issuer_host = full OIDC issuer host (no https://).
#   US region: <account>.app.us.spacelift.io
#   EU region: <account>.app.spacelift.io
spacelift_issuer_host = "dkontango.app.us.spacelift.io"
aws_region            = "us-east-1"
# Optional: tighten once stack IDs exist, e.g.
# allowed_sub = "space:*:stack:spacelift-gitops-demo-dev:run_type:*:scope:*"
