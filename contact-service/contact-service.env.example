# Non-secret config for contact-service (copy to /etc/contact-service.env).
# Secrets (SMTP user/password) are NOT here — they're read from Bao at runtime.

LISTEN_ADDR=:8080

# The exact origin of the published guide site (the only origin allowed to POST).
# GitHub Pages: https://dkontango.github.io   |  S3 website: http://<bucket>.s3-website-...
ALLOWED_ORIGIN=https://dkontango.github.io

# From identity for the thank-you email. Must be an address on a Purelymail
# domain (kontango.io/.net/.org, konoss.org, aftrserv.com).
FROM_ADDR=no-reply@kontango.io
FROM_NAME=Kontango — Spacelift GitOps Demo

# Where a separate "new contact submission" copy is sent (name/email/message,
# Reply-To set to the submitter). Leave blank to disable the admin copy.
ADMIN_ADDR=admin@kontango.us

# Bao — the agent maintains the token file separately (BAO_TOKEN_FILE in the unit).
BAO_ADDR=https://secrets.kontango.net
BAO_NAMESPACE=kontango
SMTP_SECRET_PATH=secret/data/shared/purelymail
